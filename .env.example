PORT=4000
JWT_SECRET=change-me

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# Google secrets/config
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

OPENAI_SECRET_KEY=replace-me
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash

# Self-hosted LiveKit consultation settings
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
LIVEKIT_TOKEN_TTL=2h

# Keep-alive cron (disable outside Render)
KEEP_ALIVE_ENABLED=false
# KEEP_ALIVE_URL=https://your-domain.com/api/ping
