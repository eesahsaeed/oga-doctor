PORT=4000
JWT_SECRET=change-me

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# Google secrets/config
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

OPENAI_SECRET_KEY=replace-me
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash

# LiveKit realtime consultation (required for video + conference + room chat)
LIVEKIT_URL=wss://replace-me.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
LIVEKIT_TOKEN_TTL=2h

# Optional WebRTC TURN settings (improves call reliability on strict networks)
# TURN_URLS=turn:global.turn.twilio.com:3478?transport=udp,turn:global.turn.twilio.com:3478?transport=tcp
# TURN_USERNAME=replace-me
# TURN_PASSWORD=replace-me
# Optional JSON array override:
# RTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:example.com:3478"],"username":"user","credential":"pass"}]

# Keep-alive cron (disable outside Render)
KEEP_ALIVE_ENABLED=false
# KEEP_ALIVE_URL=https://your-domain.com/api/ping
