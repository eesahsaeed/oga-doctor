PORT=4000
JWT_SECRET=change-me

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# Google secrets/config
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_WEB_CLIENT_ID=replace-me
GOOGLE_ANDROID_CLIENT_ID=replace-me
GOOGLE_IOS_CLIENT_ID=replace-me
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

OPENAI_SECRET_KEY=replace-me

# Render keep-alive (every 10 minutes)
KEEP_ALIVE_ENABLED=true
# If KEEP_ALIVE_URL is omitted, backend will use RENDER_EXTERNAL_URL/api/ping when available.
KEEP_ALIVE_URL=https://ogadoctor-backend.onrender.com/api/ping
