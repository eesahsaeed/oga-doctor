# Core runtime
NODE_ENV=production
PORT=4000
JWT_SECRET=replace-with-a-strong-secret

# AI consultation
OPENAI_SECRET_KEY=replace-me

# AWS / DynamoDB
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

# Google auth
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_WEB_CLIENT_ID=replace-me
GOOGLE_ANDROID_CLIENT_ID=replace-me
GOOGLE_IOS_CLIENT_ID=replace-me
GOOGLE_REDIRECT_URI=https://your-northflank-domain.com/api/auth/google/callback

# Frontend build-time variables (optional; defaults already work on same domain)
VITE_API_BASE_URL=/api
VITE_SOCKET_URL=https://your-northflank-domain.com

# Northflank does not sleep like Render, so disable keep-alive self-ping
KEEP_ALIVE_ENABLED=false
