{
  "name": "ogadoctor",
  "version": "1.0.0",
  "description": "React + Express + Vite fullstack boilerplate for OgaDoctor",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "npm run start -w server",
    "dev": "concurrently \"npm run dev -w client\" \"npm run start -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run start -w server",
    "build": "npm run build -w client",
    "preview": "npm run preview -w client",
    "test:server": "npm run test -w server",
    "setup": "npm install --workspaces --include-workspace-root",
    "server-build": "npm run setup",
    "server-start": "npm run start -w server",
    "client-build": "npm run setup && npm run build -w client",
    "client-start": "npm run preview -w client -- --host 0.0.0.0 --port ${PORT:-4173}"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
