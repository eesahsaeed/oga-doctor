{
  "name": "ogadoctor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build:client": "vite build",
    "build": "npm run clean && npm run build:client",
    "serve": "vite preview --host 0.0.0.0",
    "prepare": "husky install",
    "test": "node --test server/tests/*.test.js",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@heroicons/react": "^2.0.18",
    "@material-tailwind/react": "^2.1.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dynamoose": "^4.1.5",
    "dotenv": "^17.3.1",
    "ejs": "~2.6.1",
    "express": "^4.21.2",
    "express-validator": "^7.3.2",
    "framer-motion": "^12.38.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "node-cron": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.2",
    "socket.io-client": "^4.8.3",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.10",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.10",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
